{
  "folders": [
    {
      "path": ".",
      "name": "portfolio",
    },
    {
      "path": "src",
      "name": "Source",
    },
    {
      "path": "functions",
      "name": "API",
    },
    {
      "path": "public",
      "name": "Assets",
    },
  ],
  "settings": {
    "typescript.tsdk": "node_modules/typescript/lib",
    "typescript.enablePromptUseWorkspaceTsdk": true,
    "explorer.sortOrderLexicographicOptions": "type",
    "files.exclude": {
      "**/.DS_Store": true,
      "**/.git": true,
      "**/.gitignore": true,
      "**/.vscode": true,
      "**/node_modules": true,
      "**/dist": true,
      "**/.wrangler": true,
      "**/.next": true,
      "**/*.log": true,
      "**/docs": true,
      "**/scripts": false,
      "**/.claude": true,
      "public/*/legacy": true,
      "public/*/originals": true,
      "public/**/*.py": true,
      "public/**/*.DS_Store": true,
      "src/assets/originals": true,
      "src/assets/Label*": true,
      "src/main.css": true,
      "src/stores": true,
      "src/utils/__tests__": true,
      "src/hooks/useAnimations.ts": true,
      "src/utils/scrollToView.ts": true,
      "AGENTS.md": true,
      "SETUP.md": true,
      "README.md": true,
    },
    "files.watcherExclude": {
      "**/.git/objects/**": true,
      "**/.git/subtree-cache/**": true,
      "**/node_modules/**": true,
      "**/.wrangler/**": true,
      "**/dist/**": true,
      "**/.next/**": true,
      "**/.turbo/**": true,
    },
    "search.exclude": {
      "**/node_modules": true,
      "**/dist": true,
      "**/.wrangler": true,
      "**/.git": true,
      "**/docs": true,
      "public/*/legacy": true,
      "public/*/originals": true,
    },
  },
}
